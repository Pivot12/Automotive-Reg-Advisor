# Copy to .env for local dev, or set these in Vercel → Project → Settings → Environment Variables.
# Only CEREBRAS_API_KEY is required.

CEREBRAS_API_KEY=csk-your-free-cerebras-key

# Optional overrides (default model is Cerebras gpt-oss-120b — current + free tier):
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_MODEL=gpt-oss-120b
# Other valid Cerebras model IDs: qwen-3-235b-a22b-instruct , llama3.1-8b

# To use Groq free tier instead of Cerebras, set all three:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk-your-free-groq-key

# Optional: raises Jina Reader rate limits (works fine without it):
# JINA_API_KEY=jina_your-key
